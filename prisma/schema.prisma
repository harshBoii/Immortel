generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                    String                  @id @default(cuid())
  name                  String                  @db.VarChar(255)
  slug                  String                  @unique @db.VarChar(255)
  description           String?
  logoUrl               String?                 @db.VarChar(1000)
  website               String?                 @db.VarChar(500)
  email                 String                  @unique @db.VarChar(255)
  userName              String                  @unique @db.VarChar(255)
  password              String                  @db.VarChar(255)
  createdAt             DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime                @updatedAt @db.Timestamptz(3)
  aeoGenerationProfiles AeoGenerationProfile[]
  aeoPages              AeoPage[]
  assetIntelligence     AssetIntelligence[]
  assets                Asset[]
  brandEntity           BrandEntity?
  citationBounties      CitationBounty[]
  branding              CompanyBranding?
  integrationCms        CompanyIntegrationCms[]
  contentClusters       ContentCluster[]
  geoDataSources        GeoDataSource[]
  Citations             Citation[]
  LlmRadarMetrics       LlmRadarMetric[]
  llmTopics             LlmTopic[]
  microAssets           MicroAsset[]
  shopifyProducts       ShopifyProduct[]
  shopifyShops          ShopifyShop[]
  shopifyBlogChannels   ShopifyBlogChannel[]
  webinars              Webinar[]
  radarAssumption       RadarAssumption?
  llmPromptMetrics      LlmPromptMetric[]
  wordpressIntegration  WordPressIntegration?

  @@index([slug])
  @@map("companies")
}

model CompanyIntegrationCms {
  id        String              @id @default(cuid())
  companyId String
  provider  IntegrationProvider @default(Shopify)
  apiKey     String?             @db.VarChar(500)
  apiSecret  String?             @db.VarChar(500)
  scopes     String?
  appUrl     String?             @db.VarChar(2000)
  connectUrl String?             @db.VarChar(2000)
  /// Normalized *.myshopify.com — used to resolve company + CMS credentials before shop is installed
  expectedShopDomain String?     @unique @db.VarChar(255)
  createdAt  DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime            @updatedAt @db.Timestamptz(3)
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@index([companyId])
  @@map("company_integration_cms")
}

model BrandEntity {
  id                  String                 @id @default(cuid())
  companyId           String                 @unique
  canonicalName       String?                @db.VarChar(255)
  aliases             String[]               @default([])
  entityType          String                 @default("Organization") @db.VarChar(100)
  oneLiner            String?                @db.VarChar(500)
  about               String?
  industry            String?                @db.VarChar(100)
  category            String?                @db.VarChar(100)
  headquartersCity    String?                @db.VarChar(100)
  headquartersCountry String?                @db.VarChar(100)
  foundedYear         Int?
  employeeRange       String?                @db.VarChar(50)
  businessModel       String?                @db.VarChar(50)
  topics              String[]               @default([])
  keywords            String[]               @default([])
  targetAudiences     String[]               @default([])
  authorityScore      Float?
  citationCount       Int                    @default(0)
  lastCrawledAt       DateTime?              @db.Timestamptz(3)
  completenessScore   Float                  @default(0)
  lastEnrichedAt      DateTime?              @db.Timestamptz(3)
  enrichmentSource    String?                @db.VarChar(50)
  createdAt           DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime               @updatedAt @db.Timestamptz(3)
  generationProfiles  AeoGenerationProfile[]
  company             Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  intelligence        EntityIntelligence?
  offerings           EntityOffering[]
  sameAsLinks         EntitySameAsLink[]

  @@index([industry])
  @@index([completenessScore])
  @@map("brand_entities")
}

model EntityIntelligence {
  id               String      @id @default(cuid())
  entityId         String      @unique
  productDocs      String?
  marketResearch   String?
  customerFeedback String?
  createdAt        DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime    @updatedAt @db.Timestamptz(3)
  entity           BrandEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@map("entity_intelligence")
}

model EntitySameAsLink {
  id         String      @id @default(cuid())
  entityId   String
  platform   String      @db.VarChar(100)
  url        String      @db.VarChar(1000)
  verified   Boolean     @default(false)
  verifiedAt DateTime?   @db.Timestamptz(3)
  verifiedBy String?     @db.VarChar(50)
  createdAt  DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(3)
  entity     BrandEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, platform])
  @@index([entityId])
  @@index([platform])
  @@map("entity_same_as_links")
}

model EntityOffering {
  id              String       @id @default(cuid())
  entityId        String
  name            String       @db.VarChar(255)
  slug            String       @db.VarChar(255)
  description     String?
  offeringType    OfferingType @default(PRODUCT)
  url             String?      @db.VarChar(1000)
  keywords        String[]     @default([])
  useCases        String[]     @default([])
  targetAudiences String[]     @default([])
  isPrimary       Boolean      @default(false)
  isActive        Boolean      @default(true)
  differentiators String[]     @default([])
  competitors     String[]     @default([])
  createdAt       DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime     @updatedAt @db.Timestamptz(3)
  entity          BrandEntity  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, slug])
  @@index([entityId])
  @@index([offeringType])
  @@index([isPrimary])
  @@index([isActive])
  @@map("entity_offerings")
}

model CompanyBranding {
  id             String   @id @default(cuid())
  companyId      String   @unique
  logoUrl        String?  @db.VarChar(1000)
  faviconUrl     String?  @db.VarChar(1000)
  banner         String?  @db.VarChar(1000)
  themeMusic     String?  @db.VarChar(1000)
  primaryColor   String   @default("#D7765A") @db.VarChar(20)
  secondaryColor String   @default("#8B5CF6") @db.VarChar(20)
  bgColor        String   @default("#141414") @db.VarChar(20)
  surfaceColor   String   @default("#181818") @db.VarChar(20)
  textColor      String   @default("#FFFFFF") @db.VarChar(20)
  companyAddress String?  @default("123 Main St, San Francisco, CA") @db.VarChar(500)
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_branding")
}

model Asset {
  id                 String              @id @default(cuid())
  assetType          AssetType
  title              String              @db.VarChar
  filename           String              @db.VarChar
  originalSize       BigInt
  status             AssetStatus         @default(UPLOADING)
  r2Key              String              @db.VarChar(500)
  r2Bucket           String              @db.VarChar(255)
  resolution         String?             @db.VarChar(20)
  mimeType           String?             @db.VarChar(100)
  duration           Int?
  fps                Int?
  codec              String?             @db.VarChar(50)
  streamId           String?             @unique @db.VarChar(255)
  playbackUrl        String?
  thumbnailUrl       String?
  pageCount          Int?
  tags               String[]            @default([])
  metadata           Json                @default("{}")
  uploadSource       UploadSource        @default(NATIVE)
  companyId          String
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)
  intelligenceStatus IntelligenceStatus?
  aeoPageSources     AeoPageSource[]
  description        AssetDescription?
  intelligence       AssetIntelligence[]
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  geoDataSource      GeoDataSource?
  microAssets        MicroAsset[]
  streamQueueItems   StreamQueue[]
  webinars           Webinar[]

  @@index([companyId])
  @@index([assetType])
  @@index([status])
  @@index([uploadSource])
  @@index([assetType, status])
  @@index([assetType, companyId])
  @@index([createdAt(sort: Desc)])
  @@index([intelligenceStatus])
  @@map("assets")
}

model StreamQueue {
  id          String              @id @default(cuid())
  assetId     String
  r2Key       String              @db.VarChar(500)
  r2Bucket    String              @db.VarChar(255)
  status      StreamQueueStatus   @default(PENDING)
  priority    StreamQueuePriority @default(NORMAL)
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(3)
  lastError   String?
  streamId    String?             @db.VarChar(255)
  createdAt   DateTime            @default(now()) @db.Timestamptz(3)
  startedAt   DateTime?           @db.Timestamptz(3)
  completedAt DateTime?           @db.Timestamptz(3)
  asset       Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([status, priority, createdAt])
  @@index([assetId])
  @@map("stream_queue")
}

model UploadSession {
  id            String   @id @default(cuid())
  uploadId      String   @db.VarChar(255)
  key           String   @db.VarChar(500)
  fileName      String   @db.VarChar(255)
  fileSize      BigInt
  fileType      String   @db.VarChar(200)
  totalParts    Int
  uploadedParts Int[]    @default([])
  status        String   @db.VarChar(50)
  campaignId    String?  @db.VarChar(255)
  uploadedBy    String?  @db.VarChar(255)
  metadata      String?
  expiresAt     DateTime @db.Timestamptz(3)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  @@index([status])
  @@index([uploadedBy])
  @@index([campaignId])
  @@map("upload_sessions")
}

model AssetDescription {
  id         String   @id @default(cuid())
  assetId    String   @unique
  content    String
  seoTitle   String?  @db.VarChar(500)
  seoSummary String?
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("asset_descriptions")
}

model AssetIntelligence {
  id                String          @id @default(cuid())
  assetId           String
  language          String?         @db.VarChar(10)
  contentType       String?         @db.VarChar(100)
  durationSeconds   Int?
  theme             String?         @db.VarChar(255)
  sentiment         String?         @db.VarChar(50)
  intensityScore    Float?
  spiritualElements Boolean         @default(false)
  titlePrimary      String?         @db.VarChar(500)
  shortSummary      String?
  longDescription   String?
  tags              String[]        @default([])
  tone              String[]        @default([])
  topics            String[]        @default([])
  targetAudience    String[]        @default([])
  bestPlatforms     String[]        @default([])
  visualContext     String[]        @default([])
  videoGenres       String[]        @default([])
  titleVariants     Json?           @default("{}")
  chapters          Json?           @default("[]")
  shortsHooks       Json?           @default("[]")
  clipfoxInsights   Json?           @default("[]")
  modelVersion      String?         @db.VarChar(50)
  confidence        Float?
  processedAt       DateTime        @default(now()) @db.Timestamptz(3)
  companyId         String
  createdAt         DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(3)
  aeoPageSources    AeoPageSource[]
  asset             Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([companyId])
  @@index([language])
  @@index([sentiment])
  @@index([theme])
  @@index([contentType])
  @@index([spiritualElements])
  @@index([processedAt(sort: Desc)])
  @@map("asset_intelligence")
}

model MicroAsset {
  id          String           @id @default(cuid())
  assetId     String
  title       String           @db.VarChar(500)
  startTime   Float
  endTime     Float
  hook        String?
  editingIdea String?
  description String?
  thumbnail   String?          @db.VarChar(1000)
  status      MicroAssetStatus @default(DRAFT)
  category    String?          @db.VarChar(100)
  tags        String[]         @default([])
  aiGenerated Boolean          @default(false)
  confidence  Float?
  companyId   String
  createdAt   DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(3)
  approved_at DateTime?        @db.Timestamptz(3)
  is_approved Boolean          @default(false)
  shortType   ContentStyle?    @default(CASUAL)
  asset       Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([companyId])
  @@index([status])
  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@index([is_approved])
  @@map("micro_assets")
}

model Webinar {
  id                 String    @id @default(cuid())
  title              String    @db.VarChar(255)
  description        String?
  assetId            String?
  companyId          String
  scheduledAt        DateTime? @db.Timestamptz(3)
  isRecurring        Boolean   @default(false)
  recurringDayOfWeek String?   @db.VarChar(20)
  recurringTime      String?   @db.VarChar(10)
  timeZone           String?   @db.VarChar(50)
  status             String    @default("DRAFT") @db.VarChar(50)
  createdAt          DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(3)
  approved_at        DateTime? @db.Timestamptz(3)
  is_approved        Boolean   @default(false)
  asset              Asset?    @relation(fields: [assetId], references: [id])
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([assetId])
  @@index([scheduledAt])
  @@index([is_approved])
  @@map("webinars")
}

model ContentCluster {
  id           String    @id @default(cuid())
  companyId    String
  name         String    @db.VarChar(255)
  slug         String    @db.VarChar(255)
  description  String?
  pillarPageId String?   @unique
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)
  pages        AeoPage[] @relation("ClusterPages")
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pillarPage   AeoPage?  @relation("PillarPage", fields: [pillarPageId], references: [id])

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("content_clusters")
}

model AeoPage {
  id                 String                 @id @default(cuid())
  companyId          String
  slug               String                 @db.VarChar(255)
  locale             String                 @default("en") @db.VarChar(10)
  pageType           AeoPageType            @default(DEFINITION)
  status             AeoPageStatus          @default(DRAFT)
  title              String                 @db.VarChar(500)
  description        String
  facts              Json                   @default("[]")
  faq                Json                   @default("[]")
  claims             Json                   @default("[]")
  summary            Json                   @default("{}")
  knowledgeGraph     Json                   @default("{}")
  seoTitle           String?                @db.VarChar(500)
  seoDescription     String?
  canonicalUrl       String?                @db.VarChar(1000)
  clusterId          String?
  publishedAt        DateTime?              @db.Timestamptz(3)
  createdAt          DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime               @updatedAt @db.Timestamptz(3)
  generationProfiles AeoGenerationProfile[]
  sources            AeoPageSource[]
  cluster            ContentCluster?        @relation("ClusterPages", fields: [clusterId], references: [id])
  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  citationBounties   CitationBounty?
  pillarFor          ContentCluster?        @relation("PillarPage")
  aeo_pages_A        AeoPage[]              @relation("RelatedAeoPages")
  aeo_pages_B        AeoPage[]              @relation("RelatedAeoPages")

  @@unique([companyId, slug, locale])
  @@index([companyId])
  @@index([status])
  @@index([pageType])
  @@index([clusterId])
  @@index([companyId, status])
  @@index([publishedAt(sort: Desc)])
  @@map("aeo_pages")
}

model AeoGenerationProfile {
  id                     String       @id @default(cuid())
  companyId              String
  brandEntityId          String?
  baseUrl                String       @db.VarChar(1000)
  locale                 String       @default("en") @db.VarChar(10)
  clusterId              String?      @db.VarChar(255)
  existingSlugs          String[]     @default([])
  defaultPageType        AeoPageType  @default(COMPARISON)
  defaultQuery           String?
  label                  String?      @db.VarChar(255)
  slug                   String?      @db.VarChar(255)
  lastGeneratedAeoPageId String?
  lastRunAt              DateTime?    @db.Timestamptz(3)
  createdAt              DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime     @updatedAt @db.Timestamptz(3)
  brandEntity            BrandEntity? @relation(fields: [brandEntityId], references: [id])
  company                Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lastGeneratedAeoPage   AeoPage?     @relation(fields: [lastGeneratedAeoPageId], references: [id])

  @@index([companyId])
  @@index([brandEntityId])
  @@index([defaultPageType])
  @@map("aeo_generation_profiles")
}

model AeoPageSource {
  id                String             @id @default(cuid())
  pageId            String
  assetId           String?
  intelligenceId    String?
  contributionScore Float?
  createdAt         DateTime           @default(now()) @db.Timestamptz(3)
  asset             Asset?             @relation(fields: [assetId], references: [id])
  intelligence      AssetIntelligence? @relation(fields: [intelligenceId], references: [id])
  page              AeoPage            @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([assetId])
  @@map("aeo_page_sources")
}

model CitationBounty {
  id                String           @id @default(cuid())
  companyId         String
  query             String
  intent            String?          @db.VarChar(255)
  pageType          AeoPageType
  confidence        Float
  difficulty        BountyDifficulty @default(EASY)
  estimatedReach    Int?
  /// estimatedReach × (conversionRate ?? default) × (avgOrderValue ?? company AOV)
  estimatedRevenue  Float?
  /// Site / funnel conversion (e.g. 0.025); defaults applied in app when null
  conversionRate    Float?
  /// Snapshot AOV used for revenue estimate (often from Shopify catalog median)
  avgOrderValue     Float?
  suggestedCluster  String?          @db.VarChar(255)
  status            BountyStatus     @default(OPEN)
  huntedAt          DateTime?        @db.Timestamptz(3)
  /// When generated content was published (e.g. AEO page go-live)
  publishedAt       DateTime?        @db.Timestamptz(3)
  aeoPageId         String?          @unique
  generationContext Json             @default("{}")
  createdAt         DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(3)
  aeoPage           AeoPage?         @relation(fields: [aeoPageId], references: [id])
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([confidence])
  @@index([difficulty])
  @@index([companyId, status])
  @@index([companyId, status, confidence])
  @@map("citation_bounties")
}

model GeoDataSource {
  id               String        @id @default(cuid())
  companyId        String
  sourceType       GeoSourceType
  label            String        @db.VarChar(255)
  assetId          String?       @unique
  rawContent       String?
  processedContent String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @db.Timestamptz(3)
  asset            Asset?        @relation(fields: [assetId], references: [id])
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([sourceType])
  @@map("geo_data_sources")
}

model Prompt {
  id         String            @id @default(cuid())
  query      String
  topic      String?           @db.VarChar(255)
  topicId    String?
  reason     String?
  expectedRevenue Float?
  intent     String?           @db.VarChar(100)
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime          @updatedAt @db.Timestamptz(3)

  executions PromptExecution[]
  llmTopic   LlmTopic?         @relation("LlmTopicPrompts", fields: [topicId], references: [id])
  llmPromptMetrics LlmPromptMetric[]
  revenue PromptRevenue?
  rivalByModel PromptRivalByModel[]
  rivalConsensus PromptRivalConsensus[]

  @@index([intent])
  @@index([topic])
  @@index([topicId])
  @@map("llm_prompts")
}

model PromptRevenue {
  id                 String   @id @default(cuid())
  promptId           String   @unique
  monthlyPromptReach Float?
  visibilityWeight   Float?
  ctr                Float?
  cvr                Float?
  aov                Float?
  estimatedRevenue   Float?
  createdAt          DateTime @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime @updatedAt @db.Timestamptz(3)
  prompt             Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([estimatedRevenue])
  @@map("llm_prompt_revenues")
}

model PromptExecution {
  id         String     @id @default(cuid())
  promptId   String
  model      String     @db.VarChar(100)
  response   String
  executedAt DateTime   @default(now()) @db.Timestamptz(3)
  citations  Citation[]
  prompt     Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@index([model])
  @@index([executedAt])
  @@map("llm_prompt_executions")
}

  model Citation {
  id            String          @id @default(cuid())
  executionId   String
  companyId     String?
  mentionedName String          @db.VarChar(255)
  rank          Int?
  context       String?         @db.VarChar(100)
  confidence    Float?
  createdAt     DateTime        @default(now()) @db.Timestamptz(3)
  company       Company?        @relation(fields: [companyId], references: [id])
  execution     PromptExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([companyId])
  @@index([rank])
  @@map("llm_citations")
}

model LlmTopic {
  id          String     @id @default(cuid())
  name        String     @db.VarChar(255)
  description String?
  reason      String?
  createdAt   DateTime   @default(now()) @db.Timestamptz(3)
  difficulty  Difficulty @default(MEDIUM)
  companyId   String
  prompts     Prompt[]   @relation("LlmTopicPrompts")
  llmPromptMetrics LlmPromptMetric[]
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("llm_topics")
}

model PromptRivalByModel {
  id          String   @id @default(cuid())
  promptId    String
  model       String   @db.VarChar(100)
  companyName String   @db.VarChar(255)
  rank        Int?
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  prompt      Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, model, companyName])
  @@index([promptId])
  @@index([model])
  @@map("llm_prompt_rivals_by_model")
}

model PromptRivalConsensus {
  id          String   @id @default(cuid())
  promptId    String
  companyName String   @db.VarChar(255)
  avgRank     Float?
  mentions    Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
  prompt      Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, companyName])
  @@index([promptId])
  @@map("llm_prompt_rivals_consensus")
}

model LlmRadarMetric {
  id             String   @id @default(cuid())
  companyId      String
  model          String   @db.VarChar(100)
  shareOfVoice   Float?
  top3Rate       Float?
  queryCoverage  Float?
  avgRank        Float?
  calculatedAt   DateTime @default(now()) @db.Timestamptz(3)
  competitorRank Float?
  topicAuthority Float?
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([model])
  @@index([companyId, calculatedAt(sort: Desc)])
  @@map("llm_radar_metrics")
}

/// Company-level CTR/CVR assumptions for prompt revenue estimates (edit UI later)
model RadarAssumption {
  id              String   @id @default(cuid())
  companyId       String   @unique
  /// Click-through from impression to site (ratio 0–1)
  ctr             Float    @default(0.02)
  /// Conversion to order (ratio 0–1), aligned with D2C defaults when unset on bounties
  cvr             Float    @default(0.025)
  aovMultiplier   Float    @default(1)
  industryPreset  String?  @db.VarChar(50)
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("radar_assumptions")
}

/// Latest snapshot per prompt × model after a radar run (upserted on POST /api/geo/radar)
model LlmPromptMetric {
  id               String     @id @default(cuid())
  companyId        String
  promptId         String
  topicId          String?
  model            String     @db.VarChar(100)
  latestRank       Int?
  isMentioned      Boolean    @default(false)
  estimatedReach   Int?
  confidence       Float?
  difficulty       Difficulty?
  businessFit      Float?
  opportunityScore Float?
  estimatedRevenue Float?
  actionType       String?    @db.VarChar(32)
  rankTrend7d      Float?
  rankTrend30d     Float?
  modelGapFlag     Boolean    @default(false)
  calculatedAt     DateTime   @default(now()) @db.Timestamptz(3)
  company          Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  prompt           Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  llmTopic         LlmTopic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  @@unique([companyId, promptId, model])
  @@index([companyId])
  @@index([promptId])
  @@index([calculatedAt(sort: Desc)])
  @@map("llm_prompt_metrics")
}

model ShopifyShop {
  id            String           @id @default(cuid())
  companyId     String
  shopDomain    String           @unique @db.VarChar(255)
  accessToken   String           @db.VarChar(500)
  scopes        String[]         @default([])
  status        String           @default("installed") @db.VarChar(50)
  installedAt   DateTime         @default(now()) @db.Timestamptz(3)
  uninstalledAt DateTime?        @db.Timestamptz(3)
  /// Shopify GID for metafield definition `custom.json_ld` on ARTICLE owner type
  articleJsonLdMetafieldDefinitionGid String? @db.VarChar(255)
  /// Main theme ID last patched for JSON-LD injection
  mainThemeId String? @db.VarChar(255)
  /// Timestamp when the main theme was patched for JSON-LD injection
  articleJsonLdThemePatchedAt DateTime? @db.Timestamptz(3)
  createdAt     DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(3)
  products      ShopifyProduct[]
  blogChannels  ShopifyBlogChannel[]
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("shopify_shops")
}

model ShopifyBlogChannel {
  id            String     @id @default(cuid())
  shopId        String
  companyId     String
  handle        String     @db.VarChar(255)
  title         String     @db.VarChar(255)
  shopifyBlogGid String    @unique @db.VarChar(255)
  createdAt     DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(3)

  shop          ShopifyShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([shopId, handle])
  @@index([shopId])
  @@index([companyId])
  @@map("shopify_blog_channels")
}

model ShopifyProduct {
  id                   String      @id @default(cuid())
  shopId               String
  companyId            String
  shopifyGid           String      @unique @db.VarChar(255)
  title                String      @db.VarChar(500)
  status               String      @db.VarChar(50)
  handle               String      @db.VarChar(255)
  totalInventory       Int         @default(0)
  onlineStoreUrl       String?     @db.VarChar(1000)
  priceMinAmount       String?     @db.VarChar(64)
  priceMaxAmount       String?     @db.VarChar(64)
  currencyCode         String?     @db.VarChar(10)
  shopifyCreatedAt     DateTime    @db.Timestamptz(3)
  shopifyUpdatedAt     DateTime    @db.Timestamptz(3)
  createdAt            DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime    @updatedAt @db.Timestamptz(3)
  featuredImageAltText String?     @db.VarChar(500)
  featuredImageHeight  Int?
  featuredImageUrl     String?     @db.VarChar(2000)
  featuredImageWidth   Int?
  description          String?
  company              Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shop                 ShopifyShop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([companyId])
  @@index([status])
  @@map("shopify_products")
}

model WordPressIntegration {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  siteUrl     String
  authUrl     String
  userLogin   String
  credentials String
  siteTitle   String?
  status      String   @default("active")
  connectedAt DateTime @default(now())

  company Company @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("wordpress_integrations")
}

